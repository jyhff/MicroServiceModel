{
  "Clock": {
    "Kind": "Local"
  },
  "Forwarded": {
    "ForwardedHeaders": "XForwardedFor,XForwardedProto"
  },
  "AllowedHosts": "*",
  "StringEncryption": {
    "DefaultPassPhrase": "s46c5q55nxpeS8Ra",
    "InitVectorBytes": "s83ng0abvd02js84",
    "DefaultSalt": "sf&5)s3#"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "DotNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithProcessId", "WithThreadId", "WithEnvironmentName", "WithMachineName", "WithApplicationName", "WithUniqueId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Debug",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] [{SourceContext}] [{ProcessId}] [{ThreadId}] - {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/Info-.log",
          "restrictedToMinimumLevel": "Information",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "App": {
    "CorsOrigins": "http://localhost:3000,http://localhost:8080",
    "ShowPii": true
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=InteractionService;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": "5672"
  },
  "AuthServer": {
    "Authority": "http://localhost:44385",
    "RequireHttpsMetadata": false
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://localhost:5010"
      }
    }
  }
}