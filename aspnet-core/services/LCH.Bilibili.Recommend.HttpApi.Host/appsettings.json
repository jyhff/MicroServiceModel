{
  "App": {
    "CorsOrigins": "http://localhost:4200,http://localhost:3000"
  },
  "ConnectionStrings": {
    "BilibiliRecommend": "Host=localhost;Port=5432;Database=BilibiliRecommend;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "IndexPrefix": "bilibili_recommend"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Volo.Abp": "Warning"
      }
    }
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://*:5007"
      }
    }
  }
}