	<ItemGroup>
	  <None Remove="LCH\Abp\WeChat\Localization\Resources\*.json" />
	</ItemGroup>

	<ItemGroup>
	  <EmbeddedResource Include="LCH\Abp\WeChat\Localization\Resources\*.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Volo.Abp.Features" />
		<PackageReference Include="Volo.Abp.Caching" />
		<PackageReference Include="Newtonsoft.Json" />
		<PackageReference Include="Microsoft.Extensions.Http" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\LCH.Abp.WeChat.Common\LCH.Abp.WeChat.Common.csproj" />
	</ItemGroup>

</Project>
