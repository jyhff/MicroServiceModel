	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\LCH.Abp.Webhooks\LCH.Abp.Webhooks.csproj" />
		<ProjectReference Include="..\..\saas\LCH.Abp.Saas.Domain.Shared\LCH.Abp.Saas.Domain.Shared.csproj" />
	</ItemGroup>

</Project>
